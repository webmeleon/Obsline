{
  "name": "obsline-plugin",
  "version": "0.5.1",
  "description": "Obsidian plugin for Obsline – Outline Sync",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "package": "node ../scripts/package-plugin.mjs",
    "release": "npm run build && npm run package",
    "version": "node version-bump.mjs && git add manifest.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "typescript": "^5.1.0"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
